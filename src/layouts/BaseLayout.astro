---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kindex — The Memory Layer AI Coding Agents Need | Persistent Knowledge Graph for AI Workflows",
  description = "A persistent knowledge graph for AI-assisted workflows. 37 MCP tools, 5 context tiers, weighted nodes with typed edges. Your AI never starts a session blind.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Kindex" />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Kindex",
      "description": "A persistent knowledge graph for AI-assisted workflows. 37 MCP tools, 5 context tiers, weighted nodes with typed edges.",
      "url": "https://kindex.tools",
      "author": {
        "@type": "Person",
        "name": "Jeremy McEntire",
        "url": "https://perardua.dev"
      },
      "license": "https://opensource.org/licenses/MIT",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "programmingLanguage": "Python"
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <script>
      // Theme initialization
      const stored = localStorage.getItem('kindex-theme');
      if (stored === 'light') {
        document.body.classList.add('light');
      }
    </script>
    <script is:inline>
      // A6 WebMCP: expose a minimal tool surface to agent-capable browsers
      // via navigator.modelContext.provideContext({ tools: [...] }).
      // Safe no-op when the API is unavailable.
      (function () {
        try {
          var mc = navigator && navigator.modelContext;
          if (mc && typeof mc.provideContext === 'function') {
            mc.provideContext({
              tools: [
                {
                  name: 'get_mcp_server_info',
                  description: 'Return Kindex MCP server metadata',
                  inputSchema: { type: 'object', properties: {} },
                  execute: async function () {
                    return {
                      server: 'kindex',
                      transport: 'stdio',
                      install: 'pip install kindex',
                      server_card: '/.well-known/mcp/server-card.json'
                    };
                  }
                }
              ]
            });
          }
        } catch (_) {
          /* no-op */
        }
      })();
    </script>
  </body>
</html>
