---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.tsx";
import MobileNav from "../components/MobileNav.tsx";
import TerminalBlock from "../components/TerminalBlock.tsx";
import AnimatedSection from "../components/AnimatedSection.tsx";
import ContextTiers from "../components/ContextTiers.tsx";
import InstallTabs from "../components/InstallTabs.tsx";
import CommandsTabs from "../components/CommandsTabs.tsx";
---

<BaseLayout>
  <!-- ─── Navigation ─── -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 bg-nav backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="#" class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-md bg-primary flex items-center justify-center">
            <span class="text-white font-bold text-sm font-mono">K</span>
          </div>
          <span class="text-lg font-bold tracking-tight text-foreground">Kindex</span>
        </a>
        <div class="hidden sm:flex items-center gap-6">
          <a href="#features" class="text-sm text-secondary hover:text-foreground transition-colors">Features</a>
          <a href="#how-it-works" class="text-sm text-secondary hover:text-foreground transition-colors">How It Works</a>
          <a href="#use-cases" class="text-sm text-secondary hover:text-foreground transition-colors">Use Cases</a>
          <a href="#install" class="text-sm text-secondary hover:text-foreground transition-colors">Install</a>
          <a href="#commands" class="text-sm text-secondary hover:text-foreground transition-colors">Commands</a>
          <span class="w-px h-4 bg-border"></span>
          <a href="https://exemplar.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-foreground transition-colors">exemplar</a>
          <a href="https://signet.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-[#c9a227] transition-colors">signet</a>
          <a href="https://herald.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-[#22d3ee] transition-colors">herald</a>
          <a href="https://perardua.dev" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-foreground transition-colors">perardua</a>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <ThemeToggle client:load />
        <a href="https://github.com/jmcentire/kindex" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground transition-colors p-2" aria-label="View on GitHub">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <MobileNav client:load />
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- HERO                                                                    -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 pb-20 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full bg-primary/8 blur-3xl glow-orb"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="flex items-center justify-center gap-2 mb-8">
        <span class="inline-flex items-center px-3 py-1 text-xs font-mono rounded-full border border-border bg-card text-secondary">v0.12.0</span>
        <span class="inline-flex items-center px-3 py-1 text-xs rounded-full border border-border bg-card text-secondary">930+ tests passing</span>
        <span class="inline-flex items-center px-3 py-1 text-xs rounded-full border border-border bg-card text-secondary">MIT License</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6">
        The memory layer <span class="gradient-text">AI coding agents</span> don't have.
      </h1>

      <p class="text-lg sm:text-xl text-secondary max-w-2xl mx-auto mb-4">
        A persistent knowledge graph for Claude Code, Codex, and MCP-capable AI workflows. Your AI never starts a session blind.
      </p>

      <p class="text-sm text-muted max-w-xl mx-auto mb-10">
        Memory plugins capture what happened. Kindex captures what it means and how it connects.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
        <a href="#install" class="group flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold text-sm rounded-lg hover:bg-primary-bright hover:shadow-[0_0_30px_rgba(59,130,246,0.3)] transition-all">
          Get Started
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="https://github.com/jmcentire/kindex" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 border border-border text-secondary font-medium text-sm rounded-lg hover:border-border-bright hover:text-foreground transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>

      <div class="max-w-lg mx-auto">
        <TerminalBlock
          client:visible
          title="Terminal"
          lines={[
            { type: "prompt", text: "$ pip install kindex[mcp]" },
            { type: "prompt", text: "$ claude mcp add --scope user --transport stdio kindex -- kin-mcp" },
            { type: "comment", text: "# or: kin setup-codex-mcp" },
            { type: "prompt", text: "$ kin init" },
            { type: "blank", text: "" },
            { type: "output", text: "Kindex initialized. 37 MCP tools available." },
          ]}
          copyText={"pip install kindex[mcp]\nclaude mcp add --scope user --transport stdio kindex -- kin-mcp\n# or: kin setup-codex-mcp\nkin init"}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- FEATURES                                                                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="features" class="py-24 relative">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/2 right-0 w-[400px] h-[400px] rounded-full bg-purple/8 blur-3xl glow-orb"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <AnimatedSection client:visible className="text-center mb-16">
        <span class="inline-flex items-center px-3 py-1 text-xs font-mono rounded-full border border-border bg-card text-secondary mb-4">Core Capabilities</span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
          Everything your AI assistant needs to remember
        </h2>
        <p class="text-secondary max-w-xl mx-auto text-lg">
          A weighted knowledge graph that grows intelligence over time &mdash; understanding relationships, surfacing constraints, and managing context injection.
        </p>
      </AnimatedSection>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Knowledge Graph -->
        <AnimatedSection client:visible delay={0}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M12 18a4 4 0 0 0 0-6"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Knowledge Graph</h3>
            <p class="text-sm text-secondary leading-relaxed">Not a log file. Nodes with types, weights, domains. Edges with provenance and decay. The graph understands what matters.</p>
          </div>
        </AnimatedSection>

        <!-- 5 Context Tiers -->
        <AnimatedSection client:visible delay={0.08}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">5 Context Tiers</h3>
            <p class="text-sm text-secondary leading-relaxed">From 100 to 4000 tokens. Auto-selects the right depth based on your available token budget. Never eats your context window.</p>
          </div>
        </AnimatedSection>

        <!-- Operational Guardrails -->
        <AnimatedSection client:visible delay={0.16}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Operational Guardrails</h3>
            <p class="text-sm text-secondary leading-relaxed">Constraints block deploys. Directives encode preferences. Watches flag attention items. Checkpoints run pre-flight.</p>
          </div>
        </AnimatedSection>

        <!-- Team & Org Ready -->
        <AnimatedSection client:visible delay={0.24}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Team & Org Ready</h3>
            <p class="text-sm text-secondary leading-relaxed">.kin inheritance chains from service to platform to org. Private/team/org/public scoping with PII stripping on export.</p>
          </div>
        </AnimatedSection>

        <!-- Blazingly Fast -->
        <AnimatedSection client:visible delay={0.32}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Blazingly Fast</h3>
            <p class="text-sm text-secondary leading-relaxed">Hybrid FTS5 + graph traversal. 192 nodes, 11,802 edges searched in 142ms. Built on SQLite for zero-config speed.</p>
          </div>
        </AnimatedSection>

        <!-- Git Integration -->
        <AnimatedSection client:visible delay={0.40}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-pink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Git Integration</h3>
            <p class="text-sm text-secondary leading-relaxed">Auto-capture knowledge on commits. Git hooks install with one command. Your codebase history becomes searchable context.</p>
          </div>
        </AnimatedSection>

        <!-- Cache-Optimized LLM -->
        <AnimatedSection client:visible delay={0.48}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Cache-Optimized LLM</h3>
            <p class="text-sm text-secondary leading-relaxed">Three-tier prompt architecture with Anthropic prompt caching. Stable knowledge cached at 10% cost. Only the question pays full price.</p>
          </div>
        </AnimatedSection>

        <!-- Session Tags -->
        <AnimatedSection client:visible delay={0.56}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Session Tags</h3>
            <p class="text-sm text-secondary leading-relaxed">Named work context handles that replace resume files. Track focus, remaining items, and topic segments. Resume seamlessly in new sessions.</p>
          </div>
        </AnimatedSection>

        <!-- Task Management -->
        <AnimatedSection client:visible delay={0.64}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Task Management</h3>
            <p class="text-sm text-secondary leading-relaxed">Actionable work items linked to graph concepts. Tasks surface contextually via graph proximity. Priority, status, and completion tracking built in.</p>
          </div>
        </AnimatedSection>

        <!-- Reminders -->
        <AnimatedSection client:visible delay={0.72}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Reminders</h3>
            <p class="text-sm text-secondary leading-relaxed">Time-based triggers with shell commands or Claude instructions. Natural language scheduling. Snooze, execute, or complete. Fires at session start.</p>
          </div>
        </AnimatedSection>

        <!-- Watches -->
        <AnimatedSection client:visible delay={0.80}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-amber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Watches</h3>
            <p class="text-sm text-secondary leading-relaxed">Ongoing attention flags for flaky tests, unstable APIs, tech debt. Set owner and expiry. Watches surface in every session's context automatically.</p>
          </div>
        </AnimatedSection>

        <!-- Conversation Modes -->
        <AnimatedSection client:visible delay={0.88}>
          <div class="p-6 h-full border border-border bg-card rounded-xl hover:border-border-bright transition-colors">
            <svg class="w-6 h-6 mb-4 text-pink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            <h3 class="text-base font-semibold mb-2 text-foreground">Conversation Modes</h3>
            <p class="text-sm text-secondary leading-relaxed">Research-backed priming artifacts that induce processing modes in AI sessions. Five built-in modes. Create custom modes from sessions and export for team sharing.</p>
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- POLICY-GOVERNED (Security)                                              -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="py-24 relative">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/3 left-0 w-[400px] h-[400px] rounded-full bg-yellow/8 blur-3xl glow-orb"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <AnimatedSection client:visible>
          <span class="inline-flex items-center px-3 py-1 text-xs font-mono rounded-full border border-border bg-card text-secondary mb-4">Security</span>
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
            Your knowledge graph is protected
          </h2>
          <p class="text-secondary text-lg mb-6">
            signet-eval gates every tool call with deterministic policy enforcement. Define rules for what your AI can and can't do with your knowledge.
          </p>
          <p class="text-sm text-muted mb-6">
            signet-eval evaluates in ~2&micro;s. Zero runtime overhead.
          </p>
          <a
            href="https://signet.tools"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[#c9a227] hover:text-[#d4af37] transition-colors"
          >
            Learn more at signet.tools
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </a>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.15}>
          <TerminalBlock
            client:visible
            title="policy.yaml"
            lines={[
              { type: "output", text: "rules:" },
              { type: "output", text: "  - name: protect-knowledge-graph" },
              { type: "output", text: "    action: confirm" },
              { type: "output", text: "    conditions:" },
              { type: "output", text: "      - type: tool_name" },
              { type: "output", text: "        values: [Bash, Write]" },
              { type: "output", text: '    message: "Modifying files requires confirmation"' },
              { type: "blank", text: "" },
              { type: "output", text: "  - name: allow-kindex-tools" },
              { type: "output", text: "    action: allow" },
              { type: "output", text: "    conditions:" },
              { type: "output", text: "      - type: mcp_server" },
              { type: "output", text: "        values: [kindex]" },
            ]}
          />
        </AnimatedSection>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- CONTEXT TIERS                                                           -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-24 relative">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full bg-primary/8 blur-3xl glow-orb"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
